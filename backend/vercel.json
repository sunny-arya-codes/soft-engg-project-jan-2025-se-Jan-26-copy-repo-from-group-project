{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": {
                "buildCommand": "./build.sh",
                "includedFiles": [
                    "app/**/*",
                    "main.py",
                    "requirements.txt"
                ],
                "excludedFiles": [
                    "**/tests/**",
                    "**/__pycache__/**",
                    "*.md",
                    "initialize_vector_store.py",
                    "debug_vector_store.py",
                    "generate_mock_data.py"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ],
    "env": {
        "PYTHONPATH": ".",
        "MAX_WORKERS": "1",
        "VERCEL": "1"
    },
    "functions": {
        "main.py": {
            "memory": 1024,
            "maxDuration": 30
        }
    }
} 