{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": {
                "buildCommand": "./build.sh"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ],
    "env": {
        "PYTHONPATH": ".",
        "MAX_WORKERS": "1",
        "VERCEL": "1"
    },
    "functions": {
        "main.py": {
            "memory": 1024,
            "maxDuration": 10
        }
    }
} 